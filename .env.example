# Copy to .env and fill in real values. Never commit .env.

# Entra tenant the Claude Cowork gateway app lives in
TENANT_ID=00000000-0000-0000-0000-000000000000

# Azure subscription that owns the APIM + Foundry resources
SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Resource group containing the API Management instance
RESOURCE_GROUP=<resource-group>

# Name of the API Management service
APIM_NAME=<apim-name>

# Microsoft Foundry / AI Services account name and deployment
FOUNDRY_ACCOUNT=<foundry-account>
FOUNDRY_DEPLOYMENT=<deployment-name>

# Entra app registration display name + loopback redirect URI
APP_DISPLAY_NAME=Claude Cowork gateway
REDIRECT_URI=http://127.0.0.1/callback
