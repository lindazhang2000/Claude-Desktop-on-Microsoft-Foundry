# Copy to .env and fill in real values. Never commit .env.

# Entra tenant the Claude Cowork gateway app lives in
TENANT_ID=00000000-0000-0000-0000-000000000000

# Azure subscription that owns the APIM + Foundry resources
SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Resource group containing (or about to contain) the API Management instance
RESOURCE_GROUP=<resource-group>

# Azure region. Only needed when scripts/create-apim.ps1 has to provision
# a new resource group or APIM service (e.g. eastus2, swedencentral).
LOCATION=<azure-region>

# Name of the API Management service (must be globally unique when created)
APIM_NAME=<apim-name>

# APIM tier for scripts/create-apim.ps1. Consumption provisions in minutes
# and is fine for the Claude Desktop -> Foundry pattern. Use Developer/Basic/
# Standard/Premium for a dedicated tier (30-45 min provisioning).
APIM_SKU=Consumption

# Required by Azure when creating a new APIM service.
APIM_PUBLISHER_EMAIL=<you@example.com>
APIM_PUBLISHER_NAME=Claude Gateway Admin

# Microsoft Foundry / AI Services account name and deployment
FOUNDRY_ACCOUNT=<foundry-account>
FOUNDRY_DEPLOYMENT=<deployment-name>

# Entra app registration display name + loopback redirect URI
APP_DISPLAY_NAME=Claude Cowork gateway
REDIRECT_URI=http://127.0.0.1/callback
